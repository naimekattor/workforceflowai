NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Local network development:
# Use this instead of NEXTAUTH_URL when you need both localhost and a LAN IP.
AUTH_TRUST_HOST=true
NEXT_ALLOWED_DEV_ORIGINS=10.10.13.86

# Production:
# NEXTAUTH_URL=https://your-production-domain.com
# NEXT_PUBLIC_BASE_URL=https://your-api-domain.com
# Optional server-only backend URL for auth route handlers. Use this if the
# browser API URL and server API URL are different.
# BACKEND_API_URL=https://your-api-domain.com
# Optional if websocket runs on a different host. Defaults from NEXT_PUBLIC_BASE_URL.
# NEXT_PUBLIC_WS_URL=wss://your-api-domain.com
